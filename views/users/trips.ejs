<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5">
  <h2 class="fw-bold mb-4">Trips</h2>

  <% if(bookings && bookings.length > 0) { %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% for(let booking of bookings) { %>
        <% if(booking.listing) { %>
          <div class="col">
            <a href="/trips/<%= booking._id %>" class="text-decoration-none text-dark">
              <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="Listing Image" style="height: 200px; object-fit: cover;">
                <div class="card-body">
                  <h5 class="card-title fw-bold text-truncate"><%= booking.listing.title %></h5>
                  <p class="card-text text-muted mb-2"><i class="fa-solid fa-location-dot me-1"></i> <%= booking.listing.location %>, <%= booking.listing.country %></p>
                  
                  <hr>
                  
                  <div class="d-flex justify-content-between mb-1" style="font-size: 14px;">
                    <span class="text-muted fw-semibold">Check-in</span>
                    <span class="fw-bold"><%= booking.checkIn.toLocaleDateString() %></span>
                  </div>
                  <div class="d-flex justify-content-between mb-1" style="font-size: 14px;">
                    <span class="text-muted fw-semibold">Checkout</span>
                    <span class="fw-bold"><%= booking.checkOut.toLocaleDateString() %></span>
                  </div>
                  <div class="d-flex justify-content-between mb-2" style="font-size: 14px;">
                    <span class="text-muted fw-semibold">Guests</span>
                    <span class="fw-bold"><%= booking.guests %></span>
                  </div>

                  <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Total Price</span>
                    <span class="fw-bold fs-5 text-danger">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        <% } %>
      <% } %>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <h4 class="fw-semibold mt-4">No trips booked... yet!</h4>
      <p class="text-muted">Time to dust off your bags and start planning your next adventure.</p>
      <a href="/listings" class="btn btn-outline-dark fw-bold rounded-3 py-2 px-4 mt-2">Start searching</a>
    </div>
  <% } %>
</div>

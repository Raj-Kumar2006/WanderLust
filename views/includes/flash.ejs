<!-- success msg -->
<% if (success && success.length) { %>
    <div class="toast-container">
        <div class="toast-success" id="successToast">
            <div class="toast-icon">✓</div>
            <div class="toast-text">
                <%= success %>
            </div>
        </div>
    </div>
    <% } %>

        <!-- error msg -->
        <% if (error && error.length) { %>
            <div class="toast-container">
                <div class="toast-error" id="errorToast">
                    <div class="toast-icon">✖</div>
                    <div class="toast-text">
                        <%= error %>
                    </div>
                </div>
            </div>
            <% } %>


                <style>
                    /* Toast container */
                    .toast-container {
                        position: fixed;
                        top: 80px;
                        right: 20px;
                        z-index: 9999;
                    }

                    /* Success toast */
                    .toast-success {
                        display: flex;
                        align-items: center;
                        gap: 12px;
                        background: #ffffff;
                        color: #1f2937;
                        padding: 14px 18px;
                        min-width: 280px;
                        max-width: 380px;
                        border-radius: 14px;
                        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
                        border-left: 5px solid #22c55e;
                        animation: slideIn 0.4s ease, fadeOut 0.4s ease 2.6s forwards;
                    }

                    /* Error toast */
                    .toast-error {
                        display: flex;
                        align-items: center;
                        gap: 12px;
                        background: #ffffff;
                        color: #1f2937;
                        padding: 14px 18px;
                        min-width: 280px;
                        max-width: 380px;
                        border-radius: 14px;
                        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
                        border-left: 5px solid #ef4444;
                        animation: slideIn 0.4s ease, fadeOut 0.4s ease 2.6s forwards;
                    }

                    /* Icon */
                    .toast-icon {
                        width: 32px;
                        height: 32px;
                        border-radius: 50%;
                        background: #22c55e;
                        color: #fff;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 16px;
                        font-weight: bold;
                    }

                    /* Error Icon specific */
                    .toast-error .toast-icon {
                        background: #ef4444;
                    }

                    /* Text */
                    .toast-text {
                        font-size: 14.5px;
                        font-weight: 500;
                        line-height: 1.4;
                    }

                    /* Animations */
                    @keyframes slideIn {
                        from {
                            opacity: 0;
                            transform: translateX(40px);
                        }

                        to {
                            opacity: 1;
                            transform: translateX(0);
                        }
                    }

                    @keyframes fadeOut {
                        to {
                            opacity: 0;
                            transform: translateX(40px);
                        }
                    }
                </style>


                <script>
                    setTimeout(() => {
                        const flash = document.querySelector(".flash");
                        if (flash) flash.remove();
                    }, 5000);
                </script>